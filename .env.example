# Copy this file to .env and edit for your Android/Termux device.

# SSH deployment target for scripts/deploy_termux_package.sh.
PIXEL_HOST=android-device-host-or-ip
PIXEL_USER=termux-ssh-user
PIXEL_PORT=8022

# Optional: pin a private key and bypass your default SSH config.
# PIXEL_IDENTITY=$HOME/.ssh/id_ed25519
# SSH_CONFIG=/dev/null

# Optional FTP upload target for scripts/upload_aec_shim_apk.sh.
# FTP_HOST=android-device-host-or-ip:2121
# FTP_USER=ftp-user
# FTP_PASSWORD=
# FTP_PATH=dev/codex-aec-shim-debug.apk
