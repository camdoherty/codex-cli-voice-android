+use crate::app_event_sender::AppEventSender;
+use crate::legacy_core::config::Config;
+use base64::Engine;
+use codex_app_server_protocol::ThreadRealtimeAudioChunk;
+use std::collections::VecDeque;
+use std::io;
+use std::net::TcpStream;
+use std::sync::Arc;
+use std::sync::Mutex;
+use std::sync::OnceLock;
+use std::sync::atomic::AtomicBool;
+use std::sync::atomic::AtomicU16;
+use std::sync::atomic::Ordering;
+use std::sync::mpsc;
+use std::thread;
+use std::time::Duration;
+use tracing::debug;
+use tracing::warn;
+use tungstenite::Message;
+use tungstenite::WebSocket;
+use tungstenite::connect;
+use tungstenite::stream::MaybeTlsStream;
+use url::Url;
+
+const MODEL_AUDIO_SAMPLE_RATE: u32 = 24_000;
+const MODEL_AUDIO_CHANNELS: u16 = 1;
+const DEFAULT_ANDROID_AUDIO_WS_URL: &str = "ws://127.0.0.1:8765/v1/audio";
+const SOCKET_POLL_TIMEOUT: Duration = Duration::from_millis(20);
+
+static ANDROID_AUDIO_SESSION: OnceLock<Mutex<Option<Arc<AndroidAudioSession>>>> = OnceLock::new();
+
+pub struct VoiceCapture {
+    session: Arc<AndroidAudioSession>,
+    stopped: Arc<AtomicBool>,
+    last_peak: Arc<AtomicU16>,
+}
+
+impl VoiceCapture {
+    pub fn start_realtime(_config: &Config, tx: AppEventSender) -> Result<Self, String> {
+        let stopped = Arc::new(AtomicBool::new(false));
+        let last_peak = Arc::new(AtomicU16::new(0));
+        let session = AndroidAudioSession::start(tx, stopped.clone(), last_peak.clone())?;
+        Ok(Self {
+            session,
+            stopped,
+            last_peak,
+        })
+    }
+
+    pub fn stop(self) {
+        self.stopped.store(true, Ordering::SeqCst);
+        self.session.stop();
+        if let Ok(mut guard) = session_slot().lock()
+            && let Some(current) = guard.as_ref()
+            && Arc::ptr_eq(current, &self.session)
+        {
+            *guard = None;
+        }
+    }
+
+    pub fn stopped_flag(&self) -> Arc<AtomicBool> {
+        self.stopped.clone()
+    }
+
+    pub fn last_peak_arc(&self) -> Arc<AtomicU16> {
+        self.last_peak.clone()
+    }
+}
+
+pub(crate) struct RecordingMeterState {
+    history: VecDeque<char>,
+    noise_ema: f64,
+    env: f64,
+}
+
+impl RecordingMeterState {
+    pub(crate) fn new() -> Self {
+        let mut history = VecDeque::with_capacity(4);
+        while history.len() < 4 {
+            history.push_back('⠤');
+        }
+        Self {
+            history,
+            noise_ema: 0.02,
+            env: 0.0,
+        }
+    }
+
+    pub(crate) fn next_text(&mut self, peak: u16) -> String {
+        const SYMBOLS: [char; 7] = ['⠤', '⠴', '⠶', '⠷', '⡷', '⡿', '⣿'];
+        const ALPHA_NOISE: f64 = 0.05;
+        const ATTACK: f64 = 0.80;
+        const RELEASE: f64 = 0.25;
+
+        let latest_peak = peak as f64 / (i16::MAX as f64);
+
+        if latest_peak > self.env {
+            self.env = ATTACK * latest_peak + (1.0 - ATTACK) * self.env;
+        } else {
+            self.env = RELEASE * latest_peak + (1.0 - RELEASE) * self.env;
+        }
+
+        let rms_approx = self.env * 0.7;
+        self.noise_ema = (1.0 - ALPHA_NOISE) * self.noise_ema + ALPHA_NOISE * rms_approx;
+        let ref_level = self.noise_ema.max(0.01);
+        let fast_signal = 0.8 * latest_peak + 0.2 * self.env;
+        let target = 2.0f64;
+        let raw = (fast_signal / (ref_level * target)).max(0.0);
+        let k = 1.6f64;
+        let compressed = (raw.ln_1p() / k.ln_1p()).min(1.0);
+        let idx = (compressed * (SYMBOLS.len() as f64 - 1.0))
+            .round()
+            .clamp(0.0, SYMBOLS.len() as f64 - 1.0) as usize;
+        let level_char = SYMBOLS[idx];
+
+        if self.history.len() >= 4 {
+            self.history.pop_front();
+        }
+        self.history.push_back(level_char);
+
+        let mut text = String::with_capacity(4);
+        for ch in &self.history {
+            text.push(*ch);
+        }
+        text
+    }
+}
+
+pub(crate) struct RealtimeAudioPlayer {
+    session: Arc<AndroidAudioSession>,
+}
+
+impl RealtimeAudioPlayer {
+    pub(crate) fn start(_config: &Config) -> Result<Self, String> {
+        let session = existing_session()?;
+        Ok(Self { session })
+    }
+
+    pub(crate) fn enqueue_frame(&self, frame: &ThreadRealtimeAudioChunk) -> Result<(), String> {
+        if frame.num_channels == 0 || frame.sample_rate == 0 {
+            return Err("invalid realtime audio frame format".to_string());
+        }
+        let raw_bytes = base64::engine::general_purpose::STANDARD
+            .decode(&frame.data)
+            .map_err(|e| format!("failed to decode realtime audio: {e}"))?;
+        if raw_bytes.len() % 2 != 0 {
+            return Err("realtime audio frame had odd byte length".to_string());
+        }
+        let mut pcm = Vec::with_capacity(raw_bytes.len() / 2);
+        for pair in raw_bytes.chunks_exact(2) {
+            pcm.push(i16::from_le_bytes([pair[0], pair[1]]));
+        }
+        let converted = convert_pcm16(
+            &pcm,
+            frame.sample_rate,
+            frame.num_channels,
+            MODEL_AUDIO_SAMPLE_RATE,
+            MODEL_AUDIO_CHANNELS,
+        );
+        if converted.is_empty() {
+            return Ok(());
+        }
+        let mut bytes = Vec::with_capacity(converted.len() * 2);
+        for sample in converted {
+            bytes.extend_from_slice(&sample.to_le_bytes());
+        }
+        self.session.send(SessionCommand::Playback(bytes))
+    }
+
+    pub(crate) fn clear(&self) {
+        if let Err(err) = self.session.send(SessionCommand::ClearPlayback) {
+            warn!("failed to clear Android audio shim playback: {err}");
+        }
+    }
+}
+
+struct AndroidAudioSession {
+    commands: mpsc::Sender<SessionCommand>,
+    stopped: Arc<AtomicBool>,
+}
+
+impl AndroidAudioSession {
+    fn start(
+        tx: AppEventSender,
+        stopped: Arc<AtomicBool>,
+        last_peak: Arc<AtomicU16>,
+    ) -> Result<Arc<Self>, String> {
+        let mut guard = session_slot()
+            .lock()
+            .map_err(|_| "failed to lock Android audio session".to_string())?;
+        if let Some(session) = guard.as_ref()
+            && !session.stopped.load(Ordering::SeqCst)
+        {
+            return Ok(session.clone());
+        }
+
+        let url = android_audio_ws_url()?;
+        let (commands_tx, commands_rx) = mpsc::channel();
+        let session = Arc::new(Self {
+            commands: commands_tx,
+            stopped: stopped.clone(),
+        });
+        let thread_session = session.clone();
+        thread::Builder::new()
+            .name("codex-android-aec-shim".to_string())
+            .spawn(move || run_audio_session(url, tx, stopped, last_peak, commands_rx))
+            .map_err(|e| format!("failed to spawn Android audio shim thread: {e}"))?;
+        *guard = Some(thread_session.clone());
+        Ok(thread_session)
+    }
+
+    fn send(&self, command: SessionCommand) -> Result<(), String> {
+        self.commands
+            .send(command)
+            .map_err(|_| "Android audio shim session is not running".to_string())
+    }
+
+    fn stop(&self) {
+        self.stopped.store(true, Ordering::SeqCst);
+        let _ = self.commands.send(SessionCommand::Stop);
+    }
+}
+
+enum SessionCommand {
+    Playback(Vec<u8>),
+    ClearPlayback,
+    Stop,
+}
+
+fn run_audio_session(
+    url: Url,
+    tx: AppEventSender,
+    stopped: Arc<AtomicBool>,
+    last_peak: Arc<AtomicU16>,
+    commands: mpsc::Receiver<SessionCommand>,
+) {
+    if let Err(err) = run_audio_session_inner(url, tx, stopped.clone(), last_peak, commands) {
+        warn!("Android audio shim session ended: {err}");
+    }
+    stopped.store(true, Ordering::SeqCst);
+}
+
+fn run_audio_session_inner(
+    url: Url,
+    tx: AppEventSender,
+    stopped: Arc<AtomicBool>,
+    last_peak: Arc<AtomicU16>,
+    commands: mpsc::Receiver<SessionCommand>,
+) -> Result<(), String> {
+    let (mut socket, _response) = connect(url.as_str()).map_err(|e| {
+        format!(
+            "Android audio shim unavailable at {}; start the Codex AEC Shim app first: {e}",
+            url
+        )
+    })?;
+    configure_socket(&mut socket);
+
+    socket
+        .send(Message::Text("{\"type\":\"start\"}".to_string().into()))
+        .map_err(|e| format!("failed to start Android audio shim capture: {e}"))?;
+
+    while !stopped.load(Ordering::SeqCst) {
+        drain_commands(&mut socket, &commands, &stopped)?;
+        match socket.read() {
+            Ok(Message::Binary(bytes)) => {
+                let bytes = bytes.to_vec();
+                last_peak.store(peak_pcm16_le(&bytes), Ordering::Relaxed);
+                send_realtime_audio_bytes(&tx, bytes);
+            }
+            Ok(Message::Text(text)) => {
+                debug!("Android audio shim control frame: {text}");
+            }
+            Ok(Message::Ping(payload)) => {
+                socket
+                    .send(Message::Pong(payload))
+                    .map_err(|e| format!("failed to pong Android audio shim: {e}"))?;
+            }
+            Ok(Message::Pong(_)) | Ok(Message::Frame(_)) => {}
+            Ok(Message::Close(_)) => return Err("Android audio shim closed the connection".into()),
+            Err(tungstenite::Error::Io(err)) if is_timeout_or_would_block(&err) => {}
+            Err(err) => return Err(format!("failed to read Android audio shim frame: {err}")),
+        }
+    }
+
+    let _ = socket.send(Message::Text("{\"type\":\"stop\"}".to_string().into()));
+    let _ = socket.close(None);
+    Ok(())
+}
+
+fn drain_commands(
+    socket: &mut WebSocket<MaybeTlsStream<TcpStream>>,
+    commands: &mpsc::Receiver<SessionCommand>,
+    stopped: &Arc<AtomicBool>,
+) -> Result<(), String> {
+    loop {
+        match commands.try_recv() {
+            Ok(SessionCommand::Playback(bytes)) => socket
+                .send(Message::Binary(bytes.into()))
+                .map_err(|e| format!("failed to send Android audio shim playback: {e}"))?,
+            Ok(SessionCommand::ClearPlayback) => socket
+                .send(Message::Text(
+                    "{\"type\":\"playback.clear\"}".to_string().into(),
+                ))
+                .map_err(|e| format!("failed to clear Android audio shim playback: {e}"))?,
+            Ok(SessionCommand::Stop) => {
+                stopped.store(true, Ordering::SeqCst);
+                return Ok(());
+            }
+            Err(mpsc::TryRecvError::Empty) => return Ok(()),
+            Err(mpsc::TryRecvError::Disconnected) => {
+                stopped.store(true, Ordering::SeqCst);
+                return Ok(());
+            }
+        }
+    }
+}
+
+fn configure_socket(socket: &mut WebSocket<MaybeTlsStream<TcpStream>>) {
+    if let MaybeTlsStream::Plain(stream) = socket.get_mut() {
+        let _ = stream.set_read_timeout(Some(SOCKET_POLL_TIMEOUT));
+        let _ = stream.set_write_timeout(Some(SOCKET_POLL_TIMEOUT));
+    }
+}
+
+fn android_audio_ws_url() -> Result<Url, String> {
+    let value = std::env::var("CODEX_ANDROID_AUDIO_WS_URL")
+        .unwrap_or_else(|_| DEFAULT_ANDROID_AUDIO_WS_URL.to_string());
+    Url::parse(&value).map_err(|e| format!("invalid CODEX_ANDROID_AUDIO_WS_URL `{value}`: {e}"))
+}
+
+fn existing_session() -> Result<Arc<AndroidAudioSession>, String> {
+    let guard = session_slot()
+        .lock()
+        .map_err(|_| "failed to lock Android audio session".to_string())?;
+    guard
+        .as_ref()
+        .filter(|session| !session.stopped.load(Ordering::SeqCst))
+        .cloned()
+        .ok_or_else(|| "Android audio shim session is not running".to_string())
+}
+
+fn session_slot() -> &'static Mutex<Option<Arc<AndroidAudioSession>>> {
+    ANDROID_AUDIO_SESSION.get_or_init(|| Mutex::new(None))
+}
+
+fn is_timeout_or_would_block(err: &io::Error) -> bool {
+    matches!(
+        err.kind(),
+        io::ErrorKind::WouldBlock | io::ErrorKind::TimedOut
+    )
+}
+
+fn send_realtime_audio_bytes(tx: &AppEventSender, bytes: Vec<u8>) {
+    if bytes.is_empty() {
+        return;
+    }
+    let encoded = base64::engine::general_purpose::STANDARD.encode(&bytes);
+    let samples_per_channel = (bytes.len() / 2 / usize::from(MODEL_AUDIO_CHANNELS)) as u32;
+    tx.realtime_conversation_audio(ThreadRealtimeAudioChunk {
+        data: encoded,
+        sample_rate: MODEL_AUDIO_SAMPLE_RATE,
+        num_channels: MODEL_AUDIO_CHANNELS,
+        samples_per_channel: Some(samples_per_channel),
+        item_id: None,
+    });
+}
+
+fn peak_pcm16_le(bytes: &[u8]) -> u16 {
+    let mut peak: i32 = 0;
+    for pair in bytes.chunks_exact(2) {
+        let sample = i16::from_le_bytes([pair[0], pair[1]]);
+        let abs = (sample as i32).unsigned_abs() as i32;
+        if abs > peak {
+            peak = abs;
+        }
+    }
+    peak as u16
+}
+
+fn convert_pcm16(
+    input: &[i16],
+    input_sample_rate: u32,
+    input_channels: u16,
+    output_sample_rate: u32,
+    output_channels: u16,
+) -> Vec<i16> {
+    if input.is_empty() || input_channels == 0 || output_channels == 0 {
+        return Vec::new();
+    }
+
+    let in_channels = input_channels as usize;
+    let out_channels = output_channels as usize;
+    let in_frames = input.len() / in_channels;
+    if in_frames == 0 {
+        return Vec::new();
+    }
+
+    let out_frames = if input_sample_rate == output_sample_rate {
+        in_frames
+    } else {
+        (((in_frames as u64) * (output_sample_rate as u64)) / (input_sample_rate as u64)).max(1)
+            as usize
+    };
+
+    let mut out = Vec::with_capacity(out_frames.saturating_mul(out_channels));
+    for out_frame_idx in 0..out_frames {
+        let src_frame_idx = if out_frames <= 1 || in_frames <= 1 {
+            0
+        } else {
+            ((out_frame_idx as u64) * ((in_frames - 1) as u64) / ((out_frames - 1) as u64)) as usize
+        };
+        let src_start = src_frame_idx.saturating_mul(in_channels);
+        let src = &input[src_start..src_start + in_channels];
+        match (in_channels, out_channels) {
+            (1, 1) => out.push(src[0]),
+            (1, n) => {
+                for _ in 0..n {
+                    out.push(src[0]);
+                }
+            }
+            (n, 1) if n >= 2 => {
+                let sum: i32 = src.iter().map(|s| *s as i32).sum();
+                out.push((sum / (n as i32)) as i16);
+            }
+            (n, m) if n == m => out.extend_from_slice(src),
+            (n, m) if n > m => out.extend_from_slice(&src[..m]),
+            (n, m) => {
+                out.extend_from_slice(src);
+                let last = *src.last().unwrap_or(&0);
+                for _ in n..m {
+                    out.push(last);
+                }
+            }
+        }
+    }
+    out
+}
+
+#[cfg(test)]
+mod tests {
+    use super::convert_pcm16;
+    use pretty_assertions::assert_eq;
+
+    #[test]
+    fn convert_pcm16_downmixes_and_resamples_for_model_output() {
+        let input = vec![100, 300, 200, 400, 500, 700, 600, 800];
+        let converted = convert_pcm16(
+            &input, /*input_sample_rate*/ 48_000, /*input_channels*/ 2,
+            /*output_sample_rate*/ 24_000, /*output_channels*/ 1,
+        );
+        assert_eq!(converted, vec![200, 700]);
+    }
+}
