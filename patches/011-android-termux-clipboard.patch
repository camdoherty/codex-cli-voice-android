+fn arboard_copy(text: &str) -> Result<Option<ClipboardLease>, String> {
+    let mut child = std::process::Command::new("termux-clipboard-set")
+        .stdin(std::process::Stdio::piped())
+        .stdout(std::process::Stdio::null())
+        .stderr(std::process::Stdio::piped())
+        .spawn()
+        .map_err(|e| format!("failed to spawn termux-clipboard-set: {e}"))?;
+
+    let Some(mut stdin) = child.stdin.take() else {
+        let _ = child.kill();
+        let _ = child.wait();
+        return Err("failed to open termux-clipboard-set stdin".to_string());
+    };
+
+    if let Err(err) = stdin.write_all(text.as_bytes()) {
+        let _ = child.kill();
+        let _ = child.wait();
+        return Err(format!("failed to write to termux-clipboard-set: {err}"));
+    }
+
+    drop(stdin);
+
+    let output = child
+        .wait_with_output()
+        .map_err(|e| format!("failed to wait for termux-clipboard-set: {e}"))?;
+
+    if output.status.success() {
+        Ok(None)
+    } else {
+        let stderr = String::from_utf8_lossy(&output.stderr).trim().to_string();
+        if stderr.is_empty() {
+            let status = output.status;
+            Err(format!("termux-clipboard-set exited with status {status}"))
+        } else {
+            Err(format!("termux-clipboard-set failed: {stderr}"))
+        }
+    }
 }

