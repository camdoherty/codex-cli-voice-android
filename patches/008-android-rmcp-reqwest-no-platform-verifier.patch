+pub(crate) struct SharedOAuthHttpClientAdapter {
+    http_client: Arc<dyn HttpClient>,
+    default_headers: HeaderMap,
+}
+
+impl SharedOAuthHttpClientAdapter {
+    pub(crate) fn new(http_client: Arc<dyn HttpClient>, default_headers: HeaderMap) -> Self {
+        Self {
+            http_client,
+            default_headers,
+        }
+    }
+}
+
+impl OAuthHttpClient for SharedOAuthHttpClientAdapter {
+    fn execute(
+        &self,
+        request: oauth2::HttpRequest,
+        redirect_policy: OAuthRedirectPolicy,
+    ) -> Pin<Box<dyn Future<Output = Result<oauth2::HttpResponse, OAuthHttpClientError>> + Send + '_>>
+    {
+        Box::pin(async move {
+            let (parts, body) = request.into_parts();
+            let mut headers = protocol_headers(&self.default_headers);
+            for (name, value) in &parts.headers {
+                headers.push(HttpHeader {
+                    name: name.as_str().to_string(),
+                    value: value
+                        .to_str()
+                        .map_err(OAuthHttpClientError::new)?
+                        .to_string(),
+                });
+            }
+            let response = self
+                .http_client
+                .http_request(HttpRequestParams {
+                    method: parts.method.to_string(),
+                    url: parts.uri.to_string(),
+                    headers,
+                    body: Some(body.into()),
+                    timeout_ms: Some(30_000),
+                    redirect_policy: Some(match redirect_policy {
+                        OAuthRedirectPolicy::Follow => HttpRedirectPolicy::Follow,
+                        OAuthRedirectPolicy::None => HttpRedirectPolicy::None,
+                    }),
+                    request_id: "oauth-buffered-request".to_string(),
+                    stream_response: false,
+                })
+                .await
+                .map_err(OAuthHttpClientError::new)?;
+            let mut builder = oauth2::http::Response::builder().status(response.status);
+            for header in response.headers {
+                builder = builder.header(header.name, header.value);
+            }
+            builder
+                .body(response.body.into_inner())
+                .map_err(OAuthHttpClientError::new)
+        })
+    }
